.profile-container {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f7;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 用户卡片 */
.user-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999999;
}

.edit-btn {
  margin-top: 24rpx;
  padding: 12rpx 40rpx;
  background: #007aff;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.edit-form {
  width: 100%;
  margin-bottom: 16rpx;
}

.edit-input {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

/* 区块 */
.section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  display: block;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-name {
  font-size: 28rpx;
  color: #333333;
}

.member-role {
  font-size: 24rpx;
  color: #999999;
}

.member-remove {
  font-size: 26rpx;
  color: #ff3b30;
}

.empty-hint {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #bbbbbb;
}

.family-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 10rpx;
}

.action-btn {
  flex: 1;
  min-width: 180rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #007aff;
  background: rgba(0, 122, 255, 0.06);
  border-radius: 12rpx;
}

/* 退出登录 */
.logout-section {
  padding: 20rpx 0;
}

.logout-btn {
  width: 100%;
  padding: 26rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #ff3b30;
  background: rgba(255, 59, 48, 0.06);
  border-radius: 16rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-box {
  width: 560rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.invite-token {
  font-size: 32rpx;
  color: #007aff;
  font-weight: bold;
  padding: 20rpx;
  background: #f5f5f7;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  word-break: break-all;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  width: 200rpx;
  height: 72rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  background: #007aff;
  color: #ffffff;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666666;
}
