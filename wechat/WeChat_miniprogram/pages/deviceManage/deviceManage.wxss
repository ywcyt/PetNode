.page-bg { width: 100vw; height: 100vh; background-color: #f5f5f5; padding-top: 40rpx; }
.list-card { background-color: #fff; margin: 0 30rpx 30rpx; border-radius: 20rpx; padding: 30rpx 40rpx; display: flex; justify-content: space-between; align-items: center; }
.name { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.sub-info { font-size: 24rpx; color: #888; }
.unbind-btn { background-color: rgba(255, 59, 48, 0.1); color: #ff3b30; padding: 12rpx 24rpx; border-radius: 30rpx; font-size: 26rpx; font-weight: bold; }
.unbind-btn:active { opacity: 0.7; }
