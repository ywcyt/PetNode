.page-bg { width: 100vw; height: 100vh; background-color: #f5f5f5; padding-top: 40rpx; }
.member-card { background-color: #fff; margin: 0 30rpx 30rpx; border-radius: 20rpx; padding: 30rpx; display: flex; justify-content: space-between; align-items: center; }
.member-left { display: flex; align-items: center; }
.avatar { width: 90rpx; height: 90rpx; border-radius: 50%; margin-right: 20rpx; background-color: #eee; }
.name { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; display: flex; align-items: center; }
.tag { font-size: 20rpx; background-color: #07c160; color: #fff; padding: 4rpx 12rpx; border-radius: 8rpx; margin-left: 12rpx; font-weight: normal; }
.phone { font-size: 24rpx; color: #888; }
.kick-btn { background-color: rgba(255, 59, 48, 0.1); color: #ff3b30; padding: 12rpx 24rpx; border-radius: 30rpx; font-size: 26rpx; font-weight: bold; }
.kick-btn:active { opacity: 0.7; }
