/* pages/inviteRemark/inviteRemark.wxss */
.page-bg { width: 100vw; height: 100vh; background-color: #000000; box-sizing: border-box; position: relative; }
.mi-nav-header { padding-top: 110rpx; padding-left: 40rpx; padding-bottom: 40rpx; }
.mi-back-btn { font-size: 50rpx; color: #ffffff; margin-bottom: 30rpx; padding: 10rpx 40rpx 20rpx 0; font-weight: 300; }
.mi-nav-title { font-size: 52rpx; font-weight: 400; color: #ffffff; letter-spacing: 2rpx; }

.tags-container { padding: 40rpx; display: flex; flex-wrap: wrap; gap: 30rpx; }
.tag { background-color: #2c2c2e; color: #aaa; padding: 20rpx 40rpx; border-radius: 20rpx; font-size: 28rpx; transition: all 0.2s; }
.tag.active { background-color: rgba(7, 193, 96, 0.1); color: #07c160; border: 2rpx solid #07c160; }
.tag.custom { color: #07c160; }

.bottom-btns { position: absolute; bottom: 80rpx; left: 0; width: 100%; padding: 0 40rpx; box-sizing: border-box; display: flex; flex-direction: column; gap: 30rpx; }
.btn { text-align: center; padding: 35rpx 0; border-radius: 40rpx; font-size: 32rpx; font-weight: bold; }
.skip-btn { background-color: #2c2c2e; color: #aaa; }
.next-btn { background-color: #004d40; color: #07c160; } /* 墨绿色底配亮绿字的高级感 */
