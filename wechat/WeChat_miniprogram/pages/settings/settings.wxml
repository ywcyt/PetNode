<scroll-view class="settings-page {{isDark ? 'dark-theme' : 'light-theme'}}" scroll-y="true">
<!-- ✨ 植入米家风头部 -->
  <view class="mi-nav-header">
    <view class="mi-back-btn" bindtap="goBack">←</view>
    <view class="mi-nav-title">设置</view>
  </view>
  <view class="section-title">家庭与设备</view>
  <view class="group">
    <view class="cell" bindtap="navToFamily">
      <text>家庭成员管理</text><text class="arrow">›</text>
    </view>
    <view class="cell" bindtap="navToJoke">
      <text>设备共享</text><text class="arrow">›</text>
    </view>
    <view class="cell">
      <text>温度单位</text>
      <picker bindchange="onTempChange" value="{{tempIndex}}" range="{{tempArray}}">
        <view class="value-text">{{tempArray[tempIndex]}} <text class="arrow">›</text></view>
      </picker>
    </view>
    <view class="cell">
      <text>自适应模式</text>
      <switch checked="{{isDark}}" bindchange="onDarkChange" color="#07c160"/>
    </view>
  </view>

  <view class="section-title">地区与语言</view>
  <view class="group">
    <view class="cell" bindtap="navToJoke"><text>地区</text><view class="value-text">中国大陆 <text class="arrow">›</text></view></view>
    <view class="cell" bindtap="navToJoke"><text>多语言</text><view class="value-text">简体中文 <text class="arrow">›</text></view></view>
  </view>

  <view class="section-title">隐私与安全</view>
  <view class="group">
    <view class="cell" bindtap="navToJoke"><text>系统权限管理</text><text class="arrow">›</text></view>
    <view class="cell" bindtap="navToJoke"><text>人车家数据访问管理</text><text class="arrow">›</text></view>
    <view class="cell" bindtap="navToJoke"><text>法律信息及隐私管理</text><text class="arrow">›</text></view>
    <view class="cell" bindtap="navToJoke"><text>个人信息收集清单</text><text class="arrow">›</text></view>
    <view class="cell" bindtap="navToJoke"><text>第三方信息数据共享</text><text class="arrow">›</text></view>
  </view>

  <view class="section-title">关于</view>
  <view class="group">
    <view class="cell" bindtap="navToJoke"><text>关于 PetNode</text><text class="arrow">›</text></view>
    <view class="cell" bindtap="navToJoke"><text>检查更新</text><text class="arrow">›</text></view>
    <view class="cell" bindtap="navToJoke"><text>清理缓存 (117.00M)</text><text class="arrow">›</text></view>
  </view>

  <view class="logout-btn" bindtap="handleLogout">退出登录</view>
  <view style="height: 100rpx;"></view>
</scroll-view>