/* pages/login/login.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  align-items: center;
  background-color: #ffffff;
}
.header { display: flex; flex-direction: column; align-items: center; margin-top: 100rpx; }
/* 把之前的 .logo-placeholder 删掉，换成这个 */
.logo-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
 
}
.title { font-size: 48rpx; font-weight: bold; color: #333333; }
.subtitle { font-size: 28rpx; color: #888888; margin-top: 10rpx; }
.main { width: 100%; padding: 0 60rpx; box-sizing: border-box; text-align: center; }
.btn-login { width: 100% !important; border-radius: 50rpx; font-size: 32rpx; background-color: #07c160; }
.tips { display: block; font-size: 24rpx; color: #b2b2b2; margin-top: 30rpx; }