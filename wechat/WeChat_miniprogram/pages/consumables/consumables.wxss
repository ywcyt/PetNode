.consumables-page {
  width: 100vw;
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative; /* 核心：为了让返回按钮绝对定位 */
}

/* 🚨 新增返回按钮样式，位置和彩蛋页一样在左上角 */
.back-btn {
  position: absolute;
  top: 120rpx;
  left: 40rpx;
  font-size: 32rpx;
  color: #07c160;
  font-weight: bold;
  padding: 20rpx;
  z-index: 99;
}

.consumables-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.8;
}

.text {
  font-size: 28rpx;
  color: #888;
}
